{
  "expo": {
    "name": "Grace",
    "slug": "grace-prayer-app",
    "version": "1.0.0",
    "scheme": "graceapp",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0A0C14"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSPhotoLibraryAddUsageDescription": "기도문 카드 이미지를 사진 보관함에 저장합니다."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0C14"
      }
    },
    "plugins": [
      [
        "expo-media-library",
        {
          "photosPermission": "기도문 카드 이미지를 저장합니다.",
          "savePhotosPermission": "기도문 카드 이미지를 저장합니다."
        }
      ]
    ]
  }
}
